import java.util.*;

class EntityRecord {
    int enrollmentID;
    String student;
    String course;
    String instructor;
    String startDate;
    int duration;


    public EntityRecord(int enrollmentID, String student, String course,
                        String instructor, String startDate, int duration) {
        this.enrollmentID = enrollmentID;
        this.student = student;
        this.course = course;
        this.instructor = instructor;
        this.startDate = startDate;
        this.duration = duration;
    }


    public void display() {
        System.out.println("Enrollment_ID: " + enrollmentID +
                ", Student: " + student +
                ", Course: " + course +
                ", Instructor: " + instructor +
                ", Start Date: " + startDate +
                ", Duration: " + duration + " weeks");
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt(); 
        List<EntityRecord> records = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            int enrollmentID = sc.nextInt();
            String student = sc.next();
            String course = sc.next();
            String instructor = sc.next();
            String startDate = sc.next();
            int duration = sc.nextInt();

            records.add(new EntityRecord(enrollmentID, student, course, instructor, startDate, duration));
        }


        for (EntityRecord record : records) {
            record.display();
        }
    }
}
